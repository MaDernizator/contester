APP_ENV=development
APP_NAME=contester-backend
SECRET_KEY=local-dev-secret-key
DATABASE_URL=postgresql+psycopg://contester:contester@127.0.0.1:55432/contester
FLASK_APP=wsgi.py
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=8000

JUDGE_WORKSPACE_DIR=
MAX_SOURCE_CODE_LENGTH=100000

CXX_COMPILER=g++
CPP_COMPILE_TIMEOUT_SEC=15

JUDGE_EXECUTION_BACKEND=local
JUDGE_DOCKER_BINARY=docker
JUDGE_DOCKER_IMAGE=contester-judge:local

JUDGE_POLL_INTERVAL_SEC=2
JUDGE_RUNNING_SUBMISSION_TIMEOUT_SEC=300